# Server
PORT=3001
NODE_ENV=development

# PocketBase (self-hosted)
# Local dev: http://127.0.0.1:8090
# AWS EC2: http://<ec2-public-ip>:8090
POCKETBASE_URL=http://127.0.0.1:8090
POCKETBASE_EMAIL=admin@example.com
POCKETBASE_PASSWORD=password123

# CORS — comma-separated allowed origins (leave empty to allow all)
# CORS_ORIGIN=https://your-amplify-app.amplifyapp.com
